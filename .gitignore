# Managed project clones (tracked layout only via projects/.gitkeep)
projects/*
!projects/.gitkeep

# Task worktrees
worktrees/*
!worktrees/.gitkeep
projects/*/worktrees/*
!projects/*/worktrees/.gitkeep

# Workspace runtime (schema examples stay tracked)
global-status.json
nicki-workspace.yaml

# Per-task orchestration (worktree-local; durable record in docs/archive/)
current-task/*
!current-task/status.example.json

# Claude Code host layout (generated by install-claude.py)
.claude/
CLAUDE.md

# Dependencies and caches (worktrees, managed clones, legacy paths)
**/node_modules/
**/saved_games/
.pnpm-store/
