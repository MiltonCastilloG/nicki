# Managed project clones (tracked layout only via projects/.gitkeep)
projects/*
!projects/.gitkeep

# Task worktrees
worktrees/*
!worktrees/.gitkeep
projects/*/worktrees/*
!projects/*/worktrees/.gitkeep

# Workspace runtime (schema examples stay tracked)
global-status.json
nicki-workspace.yaml

# Dependencies and caches (worktrees, managed clones, legacy paths)
**/node_modules/
**/saved_games/
.pnpm-store/
